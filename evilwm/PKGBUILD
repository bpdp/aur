pkgname=evilwm
pkgver=1.5
pkgrel=1
pkgdesc='Minimalist window manager for the X Window System'
arch=('x86_64' 'i686')
url='https://www.6809.org.uk/evilwm/'
license=('custom')
depends=('libxrandr')
source=("https://www.6809.org.uk/evilwm/dl/$pkgname-$pkgver.tar.gz"
  LICENSE)
sha256sums=('6104852413e6d50669361dcadda5a25d39e2b2b0c95a6384022c905957a2740f'
  'ad86e35d4c8b6fe296f3449e3c39768169df0e8beb3ce710113d8b892362706d')

build() {
  cd "$pkgname-$pkgver"
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" desktopfilesdir=/usr/share/xsessions install
  install -D -m644 "$srcdir"/LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}
